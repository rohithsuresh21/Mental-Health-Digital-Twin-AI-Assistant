{
    "framework":  "vite",
    "buildCommand":  "vite build",
    "outputDirectory":  "dist",
    "rewrites":  [
                     {
                         "source":  "/api/(.*)",
                         "destination": "https://aaron-capability-transparency-within.trycloudflare.com/$1"
                     },
                     {
                         "source":  "/(.*)",
                         "destination":  "/index.html"
                     }
                 ]
}



